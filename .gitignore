# 本地配置（可复制 config.example.json 为 config.json 后修改）
config.json

# 分析运行时生成
projects/**/report-data.json
projects/**/status.json

# 仅跟踪 projects/example 骨架；其余子目录为本地项目数据，不提交
projects/**
!projects/example/
!projects/example/**

# Java 编译产物与反编译临时文件（根目录 DecompilerCLI.class 可提交，便于独立发行）
*.class
!DecompilerCLI.class
temp_*.java

# 可选：不把 jd-core jar 提交到 Git（发行 zip 时再放入 lib/）
# lib/*.jar
